---
import Base from '../layouts/Base.astro';

const appUrl = 'https://app.mein-kalender.link';
---

<Base title="mein-kalender.link — Alle deine Kalender an einem Ort">

  <!-- ======== Navbar ======== -->
  <nav class="navbar">
    <div class="container navbar-inner">
      <a href="/" class="navbar-brand" aria-label="mein-kalender.link Startseite">
        <img src="/logo-horizontal.svg" alt="mein-kalender.link" class="navbar-logo" width="240" height="40" />
      </a>
      <a href={`${appUrl}/auth/signup`} class="btn-primary">Jetzt starten</a>
    </div>
  </nav>

  <main>
    <!-- ======== Hero ======== -->
    <section class="hero">
      <div class="container hero-inner">
        <img src="/logo-full.svg" alt="mein-kalender.link Logo" class="hero-logo" width="340" height="170" />
        <h1 class="hero-headline">Alle deine Kalender an einem Ort</h1>
        <p class="hero-subtitle">
          Google, Outlook und ICS-Kalender zusammenführen, Termine zwischen Konten kopieren
          und Buchungsseiten für deine Verfügbarkeit erstellen.
        </p>
        <div class="hero-actions">
          <a href={`${appUrl}/auth/signup`} class="btn-primary btn-lg">Kostenlos starten</a>
          <a href="#features" class="btn-secondary btn-lg">Mehr erfahren</a>
        </div>
      </div>
    </section>

    <!-- ======== Features ======== -->
    <section id="features" class="features">
      <div class="container">
        <h2 class="section-title">Was mein-kalender.link kann</h2>
        <div class="features-grid">

          <!-- Feature 1: Consolidate -->
          <div class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <!-- Lucide: layers -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.84Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
            </div>
            <h3>Kalender zusammenführen</h3>
            <p>Google, Outlook und ICS-Kalender in einer einzigen Ansicht. Behalte den Überblick über alle deine Termine.</p>
          </div>

          <!-- Feature 2: Copy -->
          <div class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <!-- Lucide: copy -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </div>
            <h3>Kalender kopieren</h3>
            <p>Synchronisiere Termine zwischen verschiedenen Konten. Dein Arbeitskalender und Privatkalender bleiben automatisch aktuell.</p>
          </div>

          <!-- Feature 3: Booking -->
          <div class="card feature-card">
            <div class="feature-icon" aria-hidden="true">
              <!-- Lucide: calendar-check -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            </div>
            <h3>Buchungsseiten</h3>
            <p>Teile deine Verfügbarkeit und lass andere direkt Termine bei dir buchen. Einfach, ohne Hin-und-her-Mails.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ======== Trust / EU ======== -->
    <section class="trust">
      <div class="container">
        <div class="trust-card card">
          <div class="trust-icon" aria-hidden="true">
            <!-- Lucide: shield-check -->
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <div class="trust-content">
            <h2>Gehostet in der EU</h2>
            <p>
              mein-kalender.link wird ausschließlich auf Servern in der Europäischen Union betrieben.
              Deine Kalenderdaten unterliegen der DSGVO und verlassen die EU nicht.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== CTA ======== -->
    <section class="cta">
      <div class="container cta-inner">
        <h2>Bereit, deine Kalender zu vereinen?</h2>
        <p>Kostenlos starten — keine Kreditkarte nötig.</p>
        <a href={`${appUrl}/auth/signup`} class="btn-primary btn-lg">Jetzt kostenlos registrieren</a>
      </div>
    </section>
  </main>

  <!-- ======== Footer ======== -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-company">
        <p class="footer-name">Expert Sieve UG (haftungsbeschränkt)</p>
        <p class="footer-address">Wilhelm-Raabe-Str. 6, 04416 Markkleeberg</p>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </nav>
      <p class="footer-copy">&copy; {new Date().getFullYear()} Expert Sieve UG (haftungsbeschränkt). Alle Rechte vorbehalten.</p>
    </div>
  </footer>

  <style>
    /* ======== Navbar ======== */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg-primary);
      border-bottom: 1px solid var(--border-subtle);
    }
    .navbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .navbar-brand {
      display: flex;
      align-items: center;
    }
    .navbar-logo {
      height: 36px;
      width: auto;
    }

    /* ======== Hero ======== */
    .hero {
      padding: 80px 0 64px;
      text-align: center;
    }
    .hero-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-6);
    }
    .hero-logo {
      width: 280px;
      height: auto;
    }
    .hero-headline {
      font-size: 36px;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.5px;
      max-width: 600px;
    }
    .hero-subtitle {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 560px;
      line-height: 1.6;
    }
    .hero-actions {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
      justify-content: center;
      margin-top: var(--space-4);
    }

    /* ======== Features ======== */
    .features {
      padding: 80px 0;
      background: var(--bg-secondary);
    }
    .section-title {
      text-align: center;
      margin-bottom: var(--space-12);
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
    .feature-card {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      transition: box-shadow var(--transition-normal), transform var(--transition-normal);
    }
    .feature-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .feature-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: var(--radius-md);
      background: var(--color-purple-50);
      color: var(--color-purple-600);
    }
    .feature-card p {
      color: var(--text-secondary);
      font-size: 15px;
    }

    /* ======== Trust ======== */
    .trust {
      padding: 64px 0;
    }
    .trust-card {
      display: flex;
      align-items: flex-start;
      gap: var(--space-6);
      max-width: 700px;
      margin: 0 auto;
      padding: var(--space-8);
    }
    .trust-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      border-radius: var(--radius-lg);
      background: var(--color-teal-50);
      color: var(--color-teal-600);
    }
    .trust-content h2 {
      margin-bottom: var(--space-2);
    }
    .trust-content p {
      color: var(--text-secondary);
    }

    /* ======== CTA ======== */
    .cta {
      padding: 80px 0;
      background: var(--bg-secondary);
      text-align: center;
    }
    .cta-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-4);
    }
    .cta-inner p {
      color: var(--text-secondary);
      font-size: 18px;
    }
    .cta-inner .btn-primary {
      margin-top: var(--space-4);
    }

    /* ======== Footer ======== */
    .footer {
      padding: var(--space-10) 0;
      border-top: 1px solid var(--border-subtle);
    }
    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-4);
      text-align: center;
    }
    .footer-company {
      color: var(--text-secondary);
      font-size: 14px;
    }
    .footer-name {
      font-weight: 500;
    }
    .footer-address {
      color: var(--text-tertiary);
    }
    .footer-links {
      display: flex;
      gap: var(--space-6);
    }
    .footer-links a {
      font-size: 14px;
      color: var(--text-secondary);
    }
    .footer-links a:hover {
      color: var(--interactive-primary);
    }
    .footer-copy {
      font-size: 12px;
      color: var(--text-tertiary);
    }

    /* ======== Responsive ======== */
    @media (max-width: 768px) {
      .hero {
        padding: 48px 0 40px;
      }
      .hero-headline {
        font-size: 28px;
      }
      .hero-subtitle {
        font-size: 16px;
      }
      .hero-logo {
        width: 220px;
      }
      .features {
        padding: 48px 0;
      }
      .features-grid {
        grid-template-columns: 1fr;
        gap: var(--space-4);
      }
      .trust-card {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .cta {
        padding: 48px 0;
      }
    }
  </style>
</Base>
