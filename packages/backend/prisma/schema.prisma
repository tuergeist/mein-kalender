generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username               String?  @unique
  passwordHash           String?
  displayName            String?
  avatarUrl              String?
  role                   String   @default("user")
  emailVerified          Boolean  @default(false)
  bookingCalendarEntryId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  calendarSources    CalendarSource[]
  accounts           Account[]
  eventTypes         EventType[]
  availabilityRules  AvailabilityRule[]
  bookings           Booking[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model CalendarSource {
  id              String   @id @default(cuid())
  userId          String
  provider        String   // google, outlook, proton, ics
  label           String?
  credentials     String   // encrypted JSON (tokens, etc.)
  syncInterval        Int      @default(600) // seconds, default 10 min
  fetchDaysInAdvance  Int      @default(90)  // how far ahead to fetch events
  syncToken           String?
  syncStatus      String   @default("ok") // ok, syncing, error
  syncError       String?
  lastSyncAt      DateTime?
  icsUrl          String?  // for ICS URL subscriptions
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEntries CalendarEntry[]

  @@index([userId])
  @@map("calendar_sources")
}

model CalendarEntry {
  id                 String  @id @default(cuid())
  sourceId           String
  name               String
  color              String  @default("#3b82f6")
  providerCalendarId String
  isTarget           Boolean @default(false)
  syncDaysInAdvance  Int     @default(30)
  skipWorkLocation       Boolean @default(true)
  skipSingleDayAllDay   Boolean @default(false)
  skipDeclined           Boolean @default(true)
  skipFree               Boolean @default(false)
  readOnly           Boolean @default(false)
  enabled            Boolean @default(true)

  source CalendarSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  events Event[]
  targetMappings TargetEventMapping[] @relation("targetCalendar")
  sourceCalendars    CalendarEntry[] @relation("TargetSyncCalendars")
  syncTargets        CalendarEntry[] @relation("TargetSyncCalendars")
  eventTypes         EventType[]     @relation("EventTypeCalendars")

  @@index([sourceId])
  @@unique([sourceId, providerCalendarId])
  @@map("calendar_entries")
}

model Event {
  id               String   @id @default(cuid())
  calendarEntryId  String
  sourceEventId    String
  title            String
  description      String?
  location         String?
  startTime        DateTime
  endTime          DateTime
  allDay           Boolean  @default(false)
  providerMetadata Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  calendarEntry CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)
  sourceMappings  TargetEventMapping[] @relation("sourceEvent")

  @@index([calendarEntryId])
  @@index([startTime, endTime])
  @@unique([calendarEntryId, sourceEventId])
  @@map("events")
}

model TargetEventMapping {
  id                    String    @id @default(cuid())
  sourceEventId         String
  targetEventId         String    // event ID on the target provider
  targetCalendarEntryId String
  lastSyncedAt          DateTime?

  sourceEvent    Event         @relation("sourceEvent", fields: [sourceEventId], references: [id], onDelete: Cascade)
  targetCalendar CalendarEntry @relation("targetCalendar", fields: [targetCalendarEntryId], references: [id], onDelete: Cascade)

  @@index([targetCalendarEntryId])
  @@unique([sourceEventId, targetCalendarEntryId])
  @@map("target_event_mappings")
}

model EventType {
  id              String   @id @default(cuid())
  userId          String
  slug            String
  name            String
  durationMinutes Int
  description     String?
  location        String?
  color              String   @default("#3b82f6")
  enabled            Boolean  @default(true)
  redirectUrl              String?
  redirectTitle            String?
  redirectDelaySecs        Int      @default(5)
  bookingCalendarEntryId   String?
  createdAt                DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  calendars         CalendarEntry[]   @relation("EventTypeCalendars")
  availabilityRules AvailabilityRule[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("event_types")
}

model AvailabilityRule {
  id          String  @id @default(cuid())
  userId      String
  eventTypeId String?
  dayOfWeek   Int     // 0=Sun, 1=Mon, ..., 6=Sat
  startTime   String  // "HH:mm" e.g. "09:00"
  endTime     String  // "HH:mm" e.g. "17:00"
  enabled     Boolean @default(true)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType EventType? @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, eventTypeId, dayOfWeek])
  @@index([userId])
  @@map("availability_rules")
}

model Booking {
  id              String   @id @default(cuid())
  eventTypeId     String
  userId          String
  guestName       String
  guestEmail      String
  notes           String?
  startTime       DateTime
  endTime         DateTime
  status          String   @default("confirmed") // confirmed, cancelled
  providerEventId String?
  createdAt       DateTime @default(now())

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventTypeId])
  @@index([startTime, endTime])
  @@map("bookings")
}
