generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username               String?  @unique
  passwordHash           String?
  displayName            String?
  avatarUrl              String?
  role                   String   @default("user")
  emailVerified          Boolean  @default(false)
  emailVerificationToken     String?  @unique
  emailVerificationExpiresAt DateTime?
  brandColor             String?
  accentColor            String?
  backgroundUrl          String?
  backgroundOpacity      Float?
  defaultBufferBeforeMinutes Int      @default(0)
  defaultBufferAfterMinutes  Int      @default(0)
  applyBuffersToAllEvents    Boolean  @default(false)
  bookingCalendarEntryId String?
  mollieCustomerId       String?
  subscriptionId         String?
  subscriptionStatus     String?  // "active", "pending", "cancelled", "suspended"
  subscriptionPlan       String?  // "monthly", "yearly"
  trialEndsAt            DateTime?
  mcpTokenHash           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  calendarSources    CalendarSource[]
  accounts           Account[]
  eventTypes         EventType[]
  availabilityRules  AvailabilityRule[]
  bookings           Booking[]
  icsFeeds           IcsFeed[]
  images             UserImage[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model CalendarSource {
  id              String   @id @default(cuid())
  userId          String
  provider        String   // google, outlook, proton, ics
  label           String?
  credentials     String   // encrypted JSON (tokens, etc.)
  syncInterval        Int      @default(600) // seconds, default 10 min
  fetchDaysInAdvance  Int      @default(90)  // how far ahead to fetch events
  syncToken           String?
  syncStatus      String   @default("ok") // ok, syncing, error
  syncError       String?
  lastSyncAt      DateTime?
  icsUrl               String?  // for ICS URL subscriptions
  emailForInvitations  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEntries CalendarEntry[]

  @@index([userId])
  @@map("calendar_sources")
}

model CalendarEntry {
  id                 String  @id @default(cuid())
  sourceId           String
  name               String
  color              String  @default("#3b82f6")
  userColor          String?
  providerCalendarId String
  isTarget           Boolean @default(false)
  syncMode           String  @default("full") // "full" or "blocked"
  syncDaysInAdvance  Int     @default(30)
  skipWorkLocation       Boolean @default(true)
  skipSingleDayAllDay   Boolean @default(false)
  skipDeclined           Boolean @default(true)
  skipFree               Boolean @default(false)
  skipIgnored            Boolean @default(true)
  markAsPrivate          Boolean @default(false)
  readOnly           Boolean @default(false)
  enabled            Boolean @default(true)

  source CalendarSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  events Event[]
  targetMappings TargetEventMapping[] @relation("targetCalendar")
  sourceCalendars    CalendarEntry[] @relation("TargetSyncCalendars")
  syncTargets        CalendarEntry[] @relation("TargetSyncCalendars")
  eventTypes         EventType[]     @relation("EventTypeCalendars")
  icsFeeds           IcsFeed[]       @relation("IcsFeedCalendars")

  @@index([sourceId])
  @@unique([sourceId, providerCalendarId])
  @@map("calendar_entries")
}

model Event {
  id               String   @id @default(cuid())
  calendarEntryId  String
  sourceEventId    String
  title            String
  description      String?
  location         String?
  startTime        DateTime
  endTime          DateTime
  allDay           Boolean  @default(false)
  ignored          Boolean  @default(false)
  providerMetadata Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  calendarEntry CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)
  sourceMappings  TargetEventMapping[] @relation("sourceEvent")

  @@index([calendarEntryId])
  @@index([startTime, endTime])
  @@unique([calendarEntryId, sourceEventId])
  @@map("events")
}

model TargetEventMapping {
  id                    String    @id @default(cuid())
  sourceEventId         String
  targetEventId         String    // event ID on the target provider
  targetCalendarEntryId String
  lastSyncedAt          DateTime?

  sourceEvent    Event         @relation("sourceEvent", fields: [sourceEventId], references: [id], onDelete: Cascade)
  targetCalendar CalendarEntry @relation("targetCalendar", fields: [targetCalendarEntryId], references: [id], onDelete: Cascade)

  @@index([targetCalendarEntryId])
  @@unique([sourceEventId, targetCalendarEntryId])
  @@map("target_event_mappings")
}

model EventType {
  id              String   @id @default(cuid())
  userId          String
  slug            String
  name            String
  durationMinutes Int
  description     String?
  location        String?
  color              String   @default("#3b82f6")
  enabled            Boolean  @default(true)
  redirectUrl              String?
  redirectTitle            String?
  redirectDelaySecs        Int      @default(5)
  bufferBeforeMinutes      Int?
  bufferAfterMinutes       Int?
  bookingCalendarEntryId   String?
  shortHash                String?  @unique
  brandColor               String?
  accentColor              String?
  avatarUrl                String?
  backgroundUrl            String?
  backgroundOpacity        Float?
  createdAt                DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  calendars         CalendarEntry[]   @relation("EventTypeCalendars")
  availabilityRules AvailabilityRule[]
  pageViews         BookingPageView[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("event_types")
}

model AvailabilityRule {
  id          String  @id @default(cuid())
  userId      String
  eventTypeId String?
  dayOfWeek   Int     // 0=Sun, 1=Mon, ..., 6=Sat
  startTime   String  // "HH:mm" e.g. "09:00"
  endTime     String  // "HH:mm" e.g. "17:00"
  enabled     Boolean @default(true)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType EventType? @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, eventTypeId, dayOfWeek])
  @@index([userId])
  @@map("availability_rules")
}

model Booking {
  id              String   @id @default(cuid())
  eventTypeId     String
  userId          String
  guestName       String
  guestEmail      String
  notes           String?
  startTime       DateTime
  endTime         DateTime
  status          String   @default("confirmed") // confirmed, cancelled
  providerEventId String?
  managementToken          String?  @unique
  managementTokenExpiresAt DateTime?
  icsUid          String?
  icsSequence     Int      @default(0)
  createdAt       DateTime @default(now())

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventTypeId])
  @@index([startTime, endTime])
  @@map("bookings")
}

model IcsFeed {
  id             String   @id @default(cuid())
  userId         String
  name           String
  token          String   @unique
  mode           String   @default("full") // "full" or "freebusy"
  daysInAdvance  Int      @default(30)
  createdAt      DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendars CalendarEntry[] @relation("IcsFeedCalendars")

  @@index([userId])
  @@map("ics_feeds")
}

model SyncHealth {
  id              String   @id @default(cuid())
  userId          String
  sourceId        String
  provider        String
  eventsProcessed Int      @default(0)
  eventsFailed    Int      @default(0)
  latencyMs       Int      @default(0)
  checksumMatch   Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sourceId])
  @@map("sync_health")
}

model Conflict {
  id          String    @id @default(cuid())
  userId      String
  eventAId    String
  eventBId    String
  eventATitle String
  eventBTitle String
  eventAStart DateTime
  eventBStart DateTime
  eventASource String   // provider name (google, outlook, etc.)
  eventBSource String
  detectedAt  DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([userId, resolvedAt])
  @@map("conflicts")
}

model BookingPageView {
  id          String   @id @default(cuid())
  eventTypeId String
  date        DateTime @db.Date
  viewCount   Int      @default(1)

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@unique([eventTypeId, date])
  @@index([eventTypeId])
  @@map("booking_page_views")
}

model UserImage {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "avatar" or "background"
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("user_images")
}

model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String   @unique
  status    String
  processedAt DateTime @default(now())

  @@map("payment_events")
}
