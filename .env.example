# Database (local docker-compose uses port 4202)
DATABASE_URL=postgresql://calendar_sync:password@localhost:4202/calendar_sync

# Redis (local docker-compose uses port 4203)
REDIS_URL=redis://localhost:4203

# NextAuth.js
NEXTAUTH_URL=http://localhost:4201
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (for social login)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Google Calendar OAuth (for calendar source connection)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Microsoft Calendar OAuth (for calendar source connection)
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=

# Token encryption
ENCRYPTION_SECRET=your-32-byte-hex-encryption-key

# Web (Next.js dev server)
WEB_PORT=4201

# API (Fastify)
API_PORT=4200
API_HOST=0.0.0.0

# Email (for verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@calendar-sync.example.com
